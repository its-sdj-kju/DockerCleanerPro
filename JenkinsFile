pipeline {
    agent any
    stages {
        stage('Step 1: Environment Check') {
            steps {
                echo 'Verifying Docker Access...'
                sh 'docker version'
            }
        }

        stage('Step 2: Build Without Cleanup') {
            steps {
                echo 'Running docker compose without cleanup to allow conflicts...'
                sh 'docker compose up -d --build'
            }
        }
    }
}