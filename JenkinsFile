pipeline {
    agent any
    stages {
        stage('Step 1: Environment Check') {
            steps {
                echo 'Verifying Docker Access...'
                sh 'docker version' 
            }
        }
        stage('Step 2: Rebuild Docker Cleaner') {
            steps {
                echo 'Syncing project with latest GitHub code...'
                // Changed 'docker-compose' to 'docker compose'
                sh 'docker compose up -d --build app' 
            }
        }
    }
}